{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "VST3PluginTestHost Mac",
            "type": "cppdbg",
            "request": "launch",
            "program": "/Applications/VST3PluginTestHost.app",
            "args": ["--pluginfolder", "${command:cmake.buildDirectory}/vst3/Debug"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "CMake: build",
            "externalConsole": false,
            "MIMode": "lldb"
        },
        {
            "name": "EditorHost Mac",
            "type": "cppdbg",
            "request": "launch",
            "program": "${command:cmake.buildDirectory}/bin/Debug/editorhost.app/Contents/MacOS/editorhost",
            "args": ["${command:cmake.buildDirectory}/VST3/Debug/ExamplePlugin.vst3"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/Example",
            "preLaunchTask": "CMake: build",
            "externalConsole": false,
            "MIMode": "lldb"
        },
        {
            "name": "EditorHost Linux ExampleEffect",
            "type": "cppdbg",
            "request": "launch",
            "program": "${command:cmake.buildDirectory}/bin/Debug/editorhost",
            "args": ["${command:cmake.buildDirectory}/VST3/Debug/ExampleEffect.vst3"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/examples/ExampleEffect",
            "preLaunchTask": "CMake: build",
            "externalConsole": false,
            "MIMode": "gdb",
            "symbolLoadInfo": {
                "loadAll": false,
                "exceptionList": "*Example*;*singularity*;*editorhost*"
            },
            "setupCommands": [
                { "text": "set debuginfod enabled off", "ignoreFailures": true }
            ]
        },
        {
            "name": "EditorHost Linux ExampleInstrument",
            "type": "cppdbg",
            "request": "launch",
            "program": "${command:cmake.buildDirectory}/bin/Debug/editorhost",
            "args": ["${command:cmake.buildDirectory}/VST3/Debug/ExampleInstrument.vst3"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/examples/ExampleInstrument",
            "preLaunchTask": "CMake: build",
            "externalConsole": false,
            "MIMode": "gdb",
            "symbolLoadInfo": {
                "loadAll": false,
                "exceptionList": "*Example*;*singularity*;*editorhost*"
            },
            "setupCommands": [
                { "text": "set debuginfod enabled off", "ignoreFailures": true }
            ]
        },
        {
            "name": "VST3PluginTestHost Windows",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "C:/Program Files/Steinberg/VST3PluginTestHost/VST3PluginTestHost.exe",
            "args": ["--pluginfolder", "${command:cmake.buildDirectory}"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "console": "newExternalWindow",
            "preLaunchTask": "CMake: build"
        },
        {
            "name": "Editorhost Windows",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${command:cmake.buildDirectory}/bin/Debug/editorhost.exe",
            "args": ["${command:cmake.buildDirectory}/VST3/Debug/ExamplePlugin.vst3"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "console": "newExternalWindow",
            "preLaunchTask": "CMake: build"
        },
        {
            "name": "ExamplePlugin APP Windows",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            "cwd": "${workspaceFolder}/Example",
            "environment": [],
            "args": []
        },
        {
            "name": "ExamplePlugin APP Mac",
            "type": "cppdbg",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            "cwd": "${workspaceFolder}/Example",
            "environment": [],
            "args": [],
            "MIMode": "lldb"
        },
        {
            "name": "ExamplePlugin APP Linux",
            "type": "cppdbg",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            "cwd": "${workspaceFolder}/Example",
            "environment": [],
            "args": [],
            "MIMode": "gdb"
        }
    ]
}
