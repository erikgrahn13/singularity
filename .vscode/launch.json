{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "VST3PluginTestHost Mac",
            "type": "cppdbg",
            "request": "launch",
            "program": "/Applications/VST3PluginTestHost.app",
            "args": ["--pluginfolder", "${command:cmake.buildDirectory}/vst3/Debug"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "CMake: build",
            "externalConsole": false,
            "MIMode": "lldb"
        },
        {
            "name": "EditorHost Mac",
            "type": "cppdbg",
            "request": "launch",
            "program": "${command:cmake.buildDirectory}/bin/Debug/editorhost.app/Contents/MacOS/editorhost",
            "args": ["${command:cmake.buildDirectory}/vst3/Debug/HelloWorld.vst3"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "CMake: build",
            "externalConsole": false,
            "MIMode": "lldb"
        },
        {
            "name": "VST3PluginTestHost Windows",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "C:/Program Files/Steinberg/VST3PluginTestHost/VST3PluginTestHost.exe",
            "args": ["--pluginfolder", "${command:cmake.buildDirectory}"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "console": "newExternalWindow",
            "preLaunchTask": "CMake: build"
        },
        {
            "name": "Editorhost Windows",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${command:cmake.buildDirectory}/bin/Release/editorhost.exe",
            "args": ["${command:cmake.buildDirectory}/VST3/Release/ExamplePlugin.vst3"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "console": "newExternalWindow",
            "preLaunchTask": "CMake: build"
        },
        {
            "name": "ExamplePlugin APP",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            "cwd": "${workspaceFolder}/Example",
            "environment": [],
            "args": []
        }
    ]
}